{
	"name": "nellowtcs-blog",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"optimize-images": "image-transmutation --run --sourceFolder './build/images' --targetFolder './build/images.optimized' --inputFormats 'jpg' --inputFormats 'jpeg' --inputFormats 'png' --outputFormats 'png' --outputFormats 'webp' --outputFormats 'avif' && mv ./build/images ./build/images.bak && mv ./build/images.optimized ./build/images && rm -rf ./build/images.bak",
		"postbuild": "npm run optimize-images && svelte-sitemap --domain https://nellowtcs.me/",
		"vercel-sitemap": "svelte-sitemap --out-dir .vercel/output/static --domain https://nellowtcs.me/",
		"vercel-optimize-images": "image-transmutation --run --sourceFolder '.vercel/output/static/images' --targetFolder '.vercel/output/static/images.optimized' --inputFormats 'jpg' --inputFormats 'jpeg' --inputFormats 'png' --outputFormats 'png' --outputFormats 'webp' --outputFormats 'avif' && mv .vercel/output/static/images .vercel/output/static/images.bak && mv .vercel/output/static/images.optimized .vercel/output/static/images && rm -rf .vercel/output/static/images.bak",
		"vercel-build": "npm run build && npm run vercel-sitemap && npm run vercel-optimize-images"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/node": "^25.5.0",
		"dateformat": "^5.0.3",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-svelte": "^2.35.0",
		"image-transmutation": "^1.0.1",
		"mdsvex": "^0.11.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.0.0",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.0.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"sass": "^1.70.0",
		"striptags": "^3.2.0",
		"svelte": "^4.2.0",
		"svelte-check": "^3.6.0",
		"svelte-sitemap": "^3.0.0",
		"typescript": "^5.3.0",
		"vite": "^5.0.0"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/inter": "^4.5.15",
		"@fontsource/merriweather": "^4.5.14",
		"@fontsource/ubuntu-mono": "^4.5.11"
	}
}
